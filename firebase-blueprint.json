{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform (Admin, Restaurant Owner, or Customer)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "restaurant", "customer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "name"]
    },
    "Restaurant": {
      "title": "Restaurant",
      "description": "A restaurant registered on the platform",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string", "description": "UID of the restaurant owner" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "address": { "type": "string" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name", "status"]
    },
    "MenuItem": {
      "title": "MenuItem",
      "description": "A dish or item on a restaurant's menu",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "restaurantId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string", "format": "uri" },
        "stockCount": { "type": "number" },
        "isAvailable": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["restaurantId", "name", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "A food order placed by a customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "restaurantId": { "type": "string" },
        "items": { 
          "type": "array",
          "description": "List of items in the order"
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "preparing", "out-for-delivery", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "restaurantId", "items", "totalAmount", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "A review left by a customer for a restaurant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "restaurantId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "restaurantId", "rating"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/restaurants/{restaurantId}": { "schema": "Restaurant", "description": "Restaurant details" },
    "/restaurants/{restaurantId}/menu/{itemId}": { "schema": "MenuItem", "description": "Menu items for a restaurant" },
    "/orders/{orderId}": { "schema": "Order", "description": "Orders placed on the platform" },
    "/restaurants/{restaurantId}/reviews/{reviewId}": { "schema": "Review", "description": "Reviews for a restaurant" }
  }
}
